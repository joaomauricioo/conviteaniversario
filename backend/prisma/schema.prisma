generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Convidado {
  id        String   @id @default(uuid()) @db.Uuid
  nome      String
  celular   String   @unique
  presenca  Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("convidados")
}

model Presente {
  id        String   @id @default(uuid()) @db.Uuid
  nome      String
  fotoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("presentes")
}
